<UserControl x:Class="FaturaTakip.App.Views.SubscriptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Abonelikler"
                           Foreground="#1F2937"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Kurum hizmet bağlantıları ve abonelik bilgileri"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="Yeni"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="NewSubscriptionButton_Click" />
                <Button Content="Kaydet"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveSubscriptionButton_Click" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Margin="0,24,0,24">
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Toplam Abonelik"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="SubscriptionCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Aktif"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="ActiveSubscriptionCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}">
                <StackPanel>
                    <TextBlock Text="Pasif"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="PassiveSubscriptionCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.18*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.82*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource TileBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.8*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SubscriptionSearchInput"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SubscriptionFilter_Changed"
                                 ToolTip="Abonelik adı, kurum, abone no veya firma ara" />

                        <ComboBox x:Name="SubscriptionTypeFilterInput"
                                  Grid.Column="2"
                                  Height="34"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="SubscriptionFilter_Changed" />

                        <ComboBox x:Name="SubscriptionStateFilterInput"
                                  Grid.Column="4"
                                  Height="34"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="SubscriptionFilter_Changed" />
                    </Grid>

                    <DataGrid x:Name="SubscriptionGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="SubscriptionGrid_SelectionChanged"
                              BorderBrush="#E5EAF1"
                              BorderThickness="1"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tür"
                                                Binding="{Binding InvoiceTypeName}"
                                                Width="115" />
                            <DataGridTextColumn Header="Abonelik"
                                                Binding="{Binding SubscriptionName}"
                                                Width="1.2*" />
                            <DataGridTextColumn Header="Kurum"
                                                Binding="{Binding InstitutionName}"
                                                Width="1.1*" />
                            <DataGridTextColumn Header="Abone No"
                                                Binding="{Binding SubscriberNo}"
                                                Width="120" />
                            <DataGridTextColumn Header="Firma"
                                                Binding="{Binding ProviderCompany}"
                                                Width="1*" />
                            <DataGridTextColumn Header="Durum"
                                                Binding="{Binding State}"
                                                Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource TileBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SubscriptionFormTitleText"
                               Text="Yeni Abonelik"
                               Foreground="#1F2937"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,16,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Fatura Türü" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="SubscriptionInvoiceTypeInput"
                                      Height="34"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectionChanged="SubscriptionInvoiceTypeInput_SelectionChanged" />

                            <TextBlock Text="Abonelik Adı"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="SubscriptionNameInput"
                                     Height="34"
                                     MaxLength="150" />

                            <TextBlock Text="Kurum Adı"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="InstitutionNameInput"
                                     Height="34"
                                     MaxLength="150" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Abone No" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="SubscriberNoInput"
                                             Height="34"
                                             MaxLength="80" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tesisat No" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="InstallationNoInput"
                                             Height="34"
                                             MaxLength="80" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Sayaç No" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="MeterNoInput"
                                             Height="34"
                                             MaxLength="80" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Kullanım Birimi" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="SubscriptionUsageUnitInput"
                                             Height="34"
                                             MaxLength="30" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Sağlayıcı Firma"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="ProviderCompanyInput"
                                     Height="34"
                                     MaxLength="150" />

                            <TextBlock Text="Birim / Bina Adı"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="UnitNameInput"
                                     Height="34"
                                     MaxLength="150" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Başlangıç" Style="{StaticResource FieldLabel}" />
                                    <DatePicker x:Name="StartDateInput" Height="34" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Bitiş" Style="{StaticResource FieldLabel}" />
                                    <DatePicker x:Name="EndDateInput" Height="34" />
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="SubscriptionIsActiveInput"
                                      Margin="0,16,0,0"
                                      Content="Aktif"
                                      IsChecked="True" />

                            <TextBlock Text="Hizmet Adresi"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="ServiceAddressInput"
                                     MinHeight="70"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />

                            <TextBlock Text="Açıklama"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="SubscriptionDescriptionInput"
                                     MinHeight="80"
                                     MaxLength="500"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock x:Name="SubscriptionStatusText"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ToggleSubscriptionButton"
                                    Content="Pasife Al"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,0"
                                    Click="ToggleSubscriptionButton_Click" />
                            <Button Content="Kaydet"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="SaveSubscriptionButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
