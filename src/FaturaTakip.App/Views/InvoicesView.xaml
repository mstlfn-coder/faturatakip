<UserControl x:Class="FaturaTakip.App.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900" PreviewKeyDown="InvoicesView_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="ContextChipBorder" TargetType="Border">
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>
        <Style x:Key="ContextChipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Faturalar"
                           Foreground="#1F2937"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Fatura bilgisi ve PDF evrak takibi"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="Yeni"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="NewInvoiceButton_Click" />
                <Button Content="Sonrakini Hazirla"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="PrepareNextInvoiceButton_Click" />
                <Button Content="Filtreli Excel"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        ToolTip="Gorunur listedeki filtreli kayitlari Excel olarak aktarir."
                        Click="ExportInvoicesButton_Click" />
                <Button Content="Filtreli PDF"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        ToolTip="Gorunur listedeki filtreli kayitlari PDF raporu olarak aktarir."
                        Click="ExportInvoicesPdfButton_Click" />
                <Button Content="Kaydet"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveInvoiceButton_Click" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,24,0,24">
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Toplam Fatura"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="InvoiceCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Ödenmemiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="UnpaidInvoiceCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Gecikmiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="OverdueInvoiceCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}">
                <StackPanel>
                    <TextBlock Text="PDF Eksik"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="MissingPdfCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource TileBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.85*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InvoiceSearchInput"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 TextChanged="InvoiceFilter_Changed"
                                 ToolTip="Fatura no, abonelik, kurum, tür, açıklama veya PDF adı ara" />

                        <ComboBox x:Name="InvoiceTypeFilterInput"
                                  Grid.Column="2"
                                  Height="34"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InvoiceFilter_Changed"
                                  ToolTip="Fatura türü" />

                        <ComboBox x:Name="InvoiceSubscriptionFilterInput"
                                  Grid.Column="4"
                                  Height="34"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InvoiceFilter_Changed"
                                  ToolTip="Abonelik" />

                        <UniformGrid Grid.Row="1"
                                     Grid.ColumnSpan="5"
                                     Columns="6"
                                     Margin="0,10,0,0">
                            <ComboBox x:Name="InvoiceYearFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="Dönem yılı"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoiceMonthFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="Dönem ayı"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoicePaymentStatusFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="Ödeme durumu"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoicePdfStatusFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="PDF durumu"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoiceReviewStatusFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="İnceleme durumu"
                                      Margin="0,0,8,0" />
                            <Button Content="Temizle"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ClearInvoiceFiltersButton_Click" />
                        </UniformGrid>

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="5"
                              Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel VerticalAlignment="Center">
                                <Button Content="Bu Ay"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterCurrentMonthButton_Click" />
                                <Button Content="Ödenmemiş"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterUnpaidButton_Click" />
                                <Button Content="Gecikmiş"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterOverdueButton_Click" />
                                <Button Content="PDF Eksik"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterMissingPdfButton_Click" />
                                <Button Content="İncelenmedi"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterUnreviewedButton_Click" />
                                <Button Content="PDF Eksik Turu"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="StartMissingPdfReviewButton_Click" />
                                <Button Content="Gecikmiş Turu"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="StartOverdueReviewButton_Click" />
                            </WrapPanel>

                            <TextBlock x:Name="InvoiceFilterHintText"
                                       Grid.Column="1"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </Grid>
                    </Grid>

                    <DataGrid x:Name="InvoiceGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="InvoiceGrid_SelectionChanged"
                              BorderBrush="#E5EAF1"
                              BorderThickness="1"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dönem"
                                                Binding="{Binding Period}"
                                                Width="70" />
                            <DataGridTextColumn Header="Tür"
                                                Binding="{Binding InvoiceTypeName}"
                                                Width="90" />
                            <DataGridTextColumn Header="Abonelik"
                                                Binding="{Binding SubscriptionName}"
                                                Width="1.1*" />
                            <DataGridTextColumn Header="Fatura No"
                                                Binding="{Binding InvoiceNo}"
                                                Width="95" />
                            <DataGridTextColumn Header="Tutar"
                                                Binding="{Binding AmountText}"
                                                Width="85" />
                            <DataGridTextColumn Header="Ödeme"
                                                Binding="{Binding PaymentSummaryText}"
                                                Width="135" />
                            <DataGridTextColumn Header="Son Ödeme"
                                                Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                                Width="95" />
                            <DataGridTextColumn Header="Durum"
                                                Binding="{Binding State}"
                                                Width="80" />
                            <DataGridTextColumn Header="PDF"
                                                Binding="{Binding PdfState}"
                                                Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource TileBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="InvoiceFormTitleText"
                               Text="Yeni Fatura"
                               Foreground="#1F2937"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,16,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Abonelik" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="InvoiceSubscriptionInput"
                                      Height="34"
                                      DisplayMemberPath="SubscriptionName"
                                      SelectedValuePath="Id"
                                      SelectionChanged="InvoiceSubscriptionInput_SelectionChanged" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Dönem Yılı" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="InvoiceYearInput"
                                             Height="34"
                                             MaxLength="4" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Dönem Ayı" Style="{StaticResource FieldLabel}" />
                                    <ComboBox x:Name="InvoiceMonthInput"
                                              Height="34"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Fatura Tarihi" Style="{StaticResource FieldLabel}" />
                                    <DatePicker x:Name="InvoiceDateInput" Height="34" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Son Ödeme" Style="{StaticResource FieldLabel}" />
                                    <DatePicker x:Name="InvoiceDueDateInput" Height="34" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Fatura Numarası"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="InvoiceNoInput"
                                     Height="34"
                                     MaxLength="100" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Tutar" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="InvoiceAmountInput"
                                             Height="34" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Kullanım" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="UsageAmountInput"
                                             Height="34" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Kullanım Birimi"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="UsageUnitInput"
                                     Height="34"
                                     MaxLength="30" />

                            <TextBlock Text="Açıklama"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="InvoiceDescriptionInput"
                                      MinHeight="96"
                                      MaxLength="500"
                                      AcceptsReturn="True"
                                      TextWrapping="Wrap"
                                      VerticalScrollBarVisibility="Auto" />

                            <TextBlock Text="Ödeme Bilgisi"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <Border Background="#F8FAFC"
                                    BorderBrush="#DDE4EC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock x:Name="InvoicePaymentSummaryText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Ödeme Tarihi" Style="{StaticResource FieldLabel}" />
                                            <DatePicker x:Name="PaymentDateInput" Height="34" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Ödeme Tutarı" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="PaymentAmountInput"
                                                     Height="34" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Ödeme Açıklaması"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,10,0,6" />
                                    <TextBox x:Name="PaymentDescriptionInput"
                                             Height="34"
                                             MaxLength="500" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="FillRemainingPaymentButton"
                                                Content="Kalani Doldur"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="FillRemainingPaymentButton_Click" />
                                        <Button x:Name="UseSelectedPaymentTemplateButton"
                                                Content="Secili Odemeden Doldur"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="UseSelectedPaymentTemplateButton_Click" />
                                        <Button x:Name="UseLastPaymentTemplateButton"
                                                Content="Son Odemeden Doldur"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="UseLastPaymentTemplateButton_Click" />
                                        <Button x:Name="SavePaymentButton"
                                                Content="Ödeme Kaydet"
                                                Style="{StaticResource SecondaryButton}"
                                                HorizontalAlignment="Left"
                                                Click="SavePaymentButton_Click" />
                                    </StackPanel>

                                    <DataGrid x:Name="PaymentGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              Height="112"
                                              Margin="0,10,0,0"
                                              SelectionMode="Single"
                                              SelectionChanged="PaymentGrid_SelectionChanged"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              BorderBrush="#E5EAF1"
                                              BorderThickness="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Tarih"
                                                                Binding="{Binding PaymentDateText}"
                                                                Width="90" />
                                            <DataGridTextColumn Header="Tutar"
                                                                Binding="{Binding AmountText}"
                                                                Width="85" />
                                            <DataGridTextColumn Header="PDF"
                                                                Binding="{Binding PdfState}"
                                                                Width="70" />
                                            <DataGridTextColumn Header="Açıklama"
                                                                Binding="{Binding Description}"
                                                                Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock x:Name="PaymentPdfInfoText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="SelectPaymentPdfButton"
                                                Content="PDF Seç"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="SelectPaymentPdfButton_Click" />
                                        <Button x:Name="OpenPaymentPdfButton"
                                                Content="PDF Aç"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OpenPaymentPdfButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="PDF Evrakı"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <Border Background="#F8FAFC"
                                    BorderBrush="#DDE4EC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock x:Name="InvoicePdfInfoText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="İnceleme Notu"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,10,0,6" />
                                    <TextBox x:Name="InvoiceReviewNoteInput"
                                             MinHeight="72"
                                             MaxLength="500"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                    <TextBlock x:Name="InvoiceReviewedAtText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <TextBlock x:Name="InvoiceReviewHintText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <Border x:Name="InvoiceReviewContextBorder"
                                            Background="#EFF6FF"
                                            BorderBrush="#BFDBFE"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Rapor Geçiş Bağlamı"
                                                       Style="{StaticResource FieldLabel}" />
                                            <ItemsControl x:Name="InvoiceReviewContextChips"
                                                          Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource ContextChipBorder}">
                                                            <TextBlock Text="{Binding}"
                                                                       Style="{StaticResource ContextChipText}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="InvoiceReviewContextText"
                                                       Style="{StaticResource MutedText}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <CheckBox x:Name="ShowInvoiceReviewContextCheckBox"
                                                  Content="Bağlamı Göster"
                                                  IsChecked="True"
                                                  VerticalAlignment="Center"
                                                  Checked="ShowInvoiceReviewContextCheckBox_Changed"
                                                  Unchecked="ShowInvoiceReviewContextCheckBox_Changed" />
                                        <Button x:Name="CopyInvoiceReviewContextButton"
                                                Content="Bağlamı Kopyala"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="12,0,0,0"
                                                Click="CopyInvoiceReviewContextButton_Click" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="SaveInvoiceReviewNoteButton"
                                                Content="İnceleme Notunu Kaydet"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="SaveInvoiceReviewNoteButton_Click" />
                                        <Button x:Name="MarkReviewedAndNextButton"
                                                Content="Bakıldı + Sonraki"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="MarkReviewedAndNextButton_Click" />
                                        <Button x:Name="ClearInvoiceReviewNoteButton"
                                                Content="İşareti Temizle"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="ClearInvoiceReviewNoteButton_Click" />
                                        <Button Content="PDF Seç"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="SelectInvoicePdfButton_Click" />
                                        <Button x:Name="OpenInvoicePdfButton"
                                                Content="PDF Aç"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="OpenInvoicePdfButton_Click" />
                                        <Button x:Name="RevealInvoicePdfFolderButton"
                                                Content="Klasörde Göster"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="RevealInvoicePdfFolderButton_Click" />
                                        <Button x:Name="OpenInvoicePdfAndNextButton"
                                                Content="PDF Aç + Sonraki"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="OpenInvoicePdfAndNextButton_Click" />
                                        <Button x:Name="RevealInvoicePdfFolderAndNextButton"
                                                Content="Klasör + Sonraki"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="RevealInvoicePdfFolderAndNextButton_Click" />
                                        <Button x:Name="PreviousInvoiceButton"
                                                Content="Önceki Kayıt"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="PreviousInvoiceButton_Click" />
                                        <Button x:Name="NextInvoiceButton"
                                                Content="Sonraki Kayıt"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="NextInvoiceButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock x:Name="InvoiceStatusText"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <Button Content="Kaydet"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                Click="SaveInvoiceButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>






