<UserControl x:Class="FaturaTakip.App.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900" PreviewKeyDown="InvoicesView_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="ContextPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Background" Value="#2563EB" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="Tag" Value="filter" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#DCFCE7" />
                    <Setter Property="Foreground" Value="#166534" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Cursor" Value="Hand" />
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="Tag" Value="context" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Cursor" Value="Hand" />
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="Tag" Value="period" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#FEF3C7" />
                    <Setter Property="Foreground" Value="#B45309" />
                    <Setter Property="BorderBrush" Value="#FCD34D" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Cursor" Value="Hand" />
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="Tag" Value="detail" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#F3E8FF" />
                    <Setter Property="Foreground" Value="#7E22CE" />
                    <Setter Property="BorderBrush" Value="#D8B4FE" />
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Cursor" Value="Hand" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextChipBorder" TargetType="Border">
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="BorderBrush" Value="#1D4ED8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsKeyboardFocused, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="BorderBrush" Value="#0F172A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="report">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="issue">
                    <Setter Property="Background" Value="#FEE2E2" />
                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="entity">
                    <Setter Property="Background" Value="#DCFCE7" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="period">
                    <Setter Property="Background" Value="#FEF3C7" />
                    <Setter Property="BorderBrush" Value="#FCD34D" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextChipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="report">
                    <Setter Property="Foreground" Value="#1D4ED8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="issue">
                    <Setter Property="Foreground" Value="#B91C1C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="entity">
                    <Setter Property="Foreground" Value="#15803D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="period">
                    <Setter Property="Foreground" Value="#B45309" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextChipActionText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ActionKey}" Value="copy">
                    <Setter Property="Foreground" Value="#64748B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionKey}" Value="apply_filter">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionKey}" Value="apply_period">
                    <Setter Property="Foreground" Value="#B45309" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionKey}" Value="apply_type">
                    <Setter Property="Foreground" Value="#7E22CE" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionKey}" Value="apply_invoice_no">
                    <Setter Property="Foreground" Value="#7E22CE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextChipPrefixText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="report">
                    <Setter Property="Foreground" Value="#1E40AF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="issue">
                    <Setter Property="Foreground" Value="#991B1B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="entity">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="period">
                    <Setter Property="Foreground" Value="#92400E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextChipButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="ActionBadgeBorder" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="filter">
                    <Setter Property="Background" Value="#DCFCE7" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="context">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="period">
                    <Setter Property="Background" Value="#FEF3C7" />
                    <Setter Property="BorderBrush" Value="#FCD34D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="detail">
                    <Setter Property="Background" Value="#F3E8FF" />
                    <Setter Property="BorderBrush" Value="#D8B4FE" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Kind}" Value="filter" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#BBF7D0" />
                    <Setter Property="BorderBrush" Value="#16A34A" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Kind}" Value="context" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#BFDBFE" />
                    <Setter Property="BorderBrush" Value="#2563EB" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Kind}" Value="period" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FDE68A" />
                    <Setter Property="BorderBrush" Value="#D97706" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Kind}" Value="detail" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#E9D5FF" />
                    <Setter Property="BorderBrush" Value="#9333EA" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionBadgePrefixText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="filter">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="context">
                    <Setter Property="Foreground" Value="#1E40AF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="period">
                    <Setter Property="Foreground" Value="#92400E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="detail">
                    <Setter Property="Foreground" Value="#6B21A8" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionBadgeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="filter">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="context">
                    <Setter Property="Foreground" Value="#1D4ED8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="period">
                    <Setter Property="Foreground" Value="#B45309" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="detail">
                    <Setter Property="Foreground" Value="#7E22CE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReviewFocusMarkerBorder" TargetType="Border">
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="BorderBrush" Value="#93C5FD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="4,3" />
        </Style>
        <Style x:Key="ReviewFocusMarkerTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E3A8A" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ReviewFocusMarkerText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ActionBadgeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Faturalar"
                           Foreground="#1F2937"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Fatura bilgisi ve PDF evrak takibi"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="Yeni"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="NewInvoiceButton_Click" />
                <Button Content="Sonrakini Hazirla"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="PrepareNextInvoiceButton_Click" />
                <Button Content="Filtreli Excel"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        ToolTip="Gorunur listedeki filtreli kayitlari Excel olarak aktarir."
                        Click="ExportInvoicesButton_Click" />
                <Button Content="Filtreli PDF"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        ToolTip="Gorunur listedeki filtreli kayitlari PDF raporu olarak aktarir."
                        Click="ExportInvoicesPdfButton_Click" />
                <Button Content="Kaydet"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveInvoiceButton_Click" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,24,0,24">
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Toplam Fatura"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="InvoiceCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Ödenmemiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="UnpaidInvoiceCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Gecikmiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="OverdueInvoiceCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}">
                <StackPanel>
                    <TextBlock Text="PDF Eksik"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="MissingPdfCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="28"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource TileBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.85*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InvoiceSearchInput"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 TextChanged="InvoiceFilter_Changed"
                                 ToolTip="Fatura no, abonelik, kurum, tür, açıklama veya PDF adı ara" />

                        <ComboBox x:Name="InvoiceTypeFilterInput"
                                  Grid.Column="2"
                                  Height="34"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InvoiceFilter_Changed"
                                  ToolTip="Fatura türü" />

                        <ComboBox x:Name="InvoiceSubscriptionFilterInput"
                                  Grid.Column="4"
                                  Height="34"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="InvoiceFilter_Changed"
                                  ToolTip="Abonelik" />

                        <UniformGrid Grid.Row="1"
                                     Grid.ColumnSpan="5"
                                     Columns="6"
                                     Margin="0,10,0,0">
                            <ComboBox x:Name="InvoiceYearFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="Dönem yılı"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoiceMonthFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="Dönem ayı"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoicePaymentStatusFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="Ödeme durumu"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoicePdfStatusFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="PDF durumu"
                                      Margin="0,0,8,0" />
                            <ComboBox x:Name="InvoiceReviewStatusFilterInput"
                                      Height="34"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="InvoiceFilter_Changed"
                                      ToolTip="İnceleme durumu"
                                      Margin="0,0,8,0" />
                            <Button Content="Temizle"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ClearInvoiceFiltersButton_Click" />
                        </UniformGrid>

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="5"
                              Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel VerticalAlignment="Center">
                                <Button Content="Bu Ay"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterCurrentMonthButton_Click" />
                                <Button Content="Ödenmemiş"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterUnpaidButton_Click" />
                                <Button Content="Gecikmiş"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterOverdueButton_Click" />
                                <Button Content="PDF Eksik"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterMissingPdfButton_Click" />
                                <Button Content="İncelenmedi"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="QuickFilterUnreviewedButton_Click" />
                                <Button Content="PDF Eksik Turu"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="StartMissingPdfReviewButton_Click" />
                                <Button Content="Gecikmiş Turu"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0"
                                        Click="StartOverdueReviewButton_Click" />
                            </WrapPanel>

                            <TextBlock x:Name="InvoiceFilterHintText"
                                       Grid.Column="1"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </Grid>
                    </Grid>

                    <DataGrid x:Name="InvoiceGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="InvoiceGrid_SelectionChanged"
                              LoadingRow="InvoiceGrid_LoadingRow"
                              BorderBrush="#E5EAF1"
                              BorderThickness="1"
                              HeadersVisibility="All"
                              RowHeaderWidth="58"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dönem"
                                                Binding="{Binding Period}"
                                                Width="70" />
                            <DataGridTextColumn Header="Tür"
                                                Binding="{Binding InvoiceTypeName}"
                                                Width="90" />
                            <DataGridTextColumn Header="Abonelik"
                                                Binding="{Binding SubscriptionName}"
                                                Width="1.1*" />
                            <DataGridTextColumn Header="Fatura No"
                                                Binding="{Binding InvoiceNo}"
                                                Width="95" />
                            <DataGridTextColumn Header="Tutar"
                                                Binding="{Binding AmountText}"
                                                Width="85" />
                            <DataGridTextColumn Header="Ödeme"
                                                Binding="{Binding PaymentSummaryText}"
                                                Width="135" />
                            <DataGridTextColumn Header="Son Ödeme"
                                                Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                                                Width="95" />
                            <DataGridTextColumn Header="Durum"
                                                Binding="{Binding State}"
                                                Width="80" />
                            <DataGridTextColumn Header="PDF"
                                                Binding="{Binding PdfState}"
                                                Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource TileBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="InvoiceFormTitleText"
                                   Text="Yeni Fatura"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="InvoiceFormContextHintText"
                                   Margin="0,6,0,0"
                                   Foreground="#475569"
                                   FontSize="12"
                                   Visibility="Collapsed" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,16,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Abonelik" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="InvoiceSubscriptionInput"
                                      Height="34"
                                      DisplayMemberPath="SubscriptionName"
                                      SelectedValuePath="Id"
                                      SelectionChanged="InvoiceSubscriptionInput_SelectionChanged" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Dönem Yılı" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="InvoiceYearInput"
                                             Height="34"
                                             MaxLength="4" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Dönem Ayı" Style="{StaticResource FieldLabel}" />
                                    <ComboBox x:Name="InvoiceMonthInput"
                                              Height="34"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Fatura Tarihi" Style="{StaticResource FieldLabel}" />
                                    <DatePicker x:Name="InvoiceDateInput" Height="34" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Son Ödeme" Style="{StaticResource FieldLabel}" />
                                    <DatePicker x:Name="InvoiceDueDateInput" Height="34" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Fatura Numarası"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="InvoiceNoInput"
                                     Height="34"
                                     MaxLength="100" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Tutar" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="InvoiceAmountInput"
                                             Height="34" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Kullanım" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="UsageAmountInput"
                                             Height="34" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Kullanım Birimi"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="UsageUnitInput"
                                     Height="34"
                                     MaxLength="30" />

                            <TextBlock Text="Açıklama"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <TextBox x:Name="InvoiceDescriptionInput"
                                      MinHeight="96"
                                      MaxLength="500"
                                      AcceptsReturn="True"
                                      TextWrapping="Wrap"
                                      VerticalScrollBarVisibility="Auto" />

                            <TextBlock Text="Ödeme Bilgisi"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <Border Background="#F8FAFC"
                                    BorderBrush="#DDE4EC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock x:Name="InvoicePaymentSummaryText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Ödeme Tarihi" Style="{StaticResource FieldLabel}" />
                                            <DatePicker x:Name="PaymentDateInput" Height="34" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Ödeme Tutarı" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="PaymentAmountInput"
                                                     Height="34" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Ödeme Açıklaması"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,10,0,6" />
                                    <TextBox x:Name="PaymentDescriptionInput"
                                             Height="34"
                                             MaxLength="500" />
                                    <TextBlock x:Name="PaymentHelperSummaryText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <ItemsControl x:Name="PaymentHelperBadges"
                                                  Margin="0,6,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource ActionBadgeButton}"
                                                        Tag="{Binding ActionKey}"
                                                        ToolTip="{Binding ToolTip}"
                                                        Click="PaymentHelperBadgeButton_Click">
                                                    <Border Style="{StaticResource ActionBadgeBorder}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Prefix}"
                                                                       Style="{StaticResource ActionBadgePrefixText}" />
                                                            <TextBlock Text="{Binding Text}"
                                                                       Style="{StaticResource ActionBadgeText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="FillRemainingPaymentButton"
                                                Content="Kalani Doldur"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="FillRemainingPaymentButton_Click" />
                                        <Button x:Name="UseSelectedPaymentTemplateButton"
                                                Content="Secili Odemeden Doldur"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="UseSelectedPaymentTemplateButton_Click" />
                                        <Button x:Name="UseLastPaymentTemplateButton"
                                                Content="Son Odemeden Doldur"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="UseLastPaymentTemplateButton_Click" />
                                        <Button x:Name="SavePaymentButton"
                                                Content="Ödeme Kaydet"
                                                Style="{StaticResource SecondaryButton}"
                                                HorizontalAlignment="Left"
                                                Click="SavePaymentButton_Click" />
                                    </StackPanel>

                                    <DataGrid x:Name="PaymentGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              Height="112"
                                              Margin="0,10,0,0"
                                              SelectionMode="Single"
                                              SelectionChanged="PaymentGrid_SelectionChanged"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              BorderBrush="#E5EAF1"
                                              BorderThickness="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Tarih"
                                                                Binding="{Binding PaymentDateText}"
                                                                Width="90" />
                                            <DataGridTextColumn Header="Tutar"
                                                                Binding="{Binding AmountText}"
                                                                Width="85" />
                                            <DataGridTextColumn Header="PDF"
                                                                Binding="{Binding PdfState}"
                                                                Width="70" />
                                            <DataGridTextColumn Header="Açıklama"
                                                                Binding="{Binding Description}"
                                                                Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock x:Name="PaymentPdfInfoText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="SelectPaymentPdfButton"
                                                Content="PDF Seç"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="SelectPaymentPdfButton_Click" />
                                        <Button x:Name="OpenPaymentPdfButton"
                                                Content="PDF Aç"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OpenPaymentPdfButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="PDF Evrakı"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,14,0,6" />
                            <Border Background="#F8FAFC"
                                    BorderBrush="#DDE4EC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock x:Name="InvoicePdfInfoText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="İnceleme Notu"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,10,0,6" />
                                    <TextBox x:Name="InvoiceReviewNoteInput"
                                             MinHeight="72"
                                             MaxLength="500"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                    <TextBlock x:Name="InvoiceReviewedAtText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <TextBlock x:Name="InvoiceReviewHintText"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <Border x:Name="InvoiceReviewContextBorder"
                                            Background="#EFF6FF"
                                            BorderBrush="#BFDBFE"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Rapor Geçiş Bağlamı"
                                                       Style="{StaticResource FieldLabel}" />
                                            <ItemsControl x:Name="InvoiceReviewContextChips"
                                                          Margin="0,4,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource ContextChipButton}"
                                                                Tag="{Binding}"
                                                                ToolTip="{Binding ToolTip}"
                                                                Click="InvoiceReviewContextChipButton_Click"
                                                                KeyDown="InvoiceReviewContextChipButton_KeyDown"
                                                                MouseRightButtonUp="InvoiceReviewContextChipButton_MouseRightButtonUp">
                                                            <Border Style="{StaticResource ContextChipBorder}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Prefix}"
                                                                               Style="{StaticResource ContextChipPrefixText}" />
                                                                    <TextBlock Text="{Binding Text}"
                                                                               Style="{StaticResource ContextChipText}" />
                                                                    <TextBlock Text="{Binding ActionBadge}"
                                                                               Style="{StaticResource ContextChipActionText}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="InvoiceReviewContextText"
                                                       Style="{StaticResource MutedText}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <ItemsControl x:Name="InvoiceReviewActionBadges"
                                                          Margin="0,8,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource ActionBadgeButton}"
                                                                Tag="{Binding ActionKey}"
                                                                ToolTip="{Binding ToolTip}"
                                                                Click="InvoiceReviewActionBadgeButton_Click">
                                                            <Border Style="{StaticResource ActionBadgeBorder}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Prefix}"
                                                                               Style="{StaticResource ActionBadgePrefixText}" />
                                                                    <TextBlock Text="{Binding Text}"
                                                                               Style="{StaticResource ActionBadgeText}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock x:Name="InvoiceReviewLastActionText"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Visibility="Collapsed" />
                                            <CheckBox x:Name="ShowInvoiceReviewContextDetailsCheckBox"
                                                      Content="Detay Metin"
                                                      Margin="0,6,0,0"
                                                      VerticalAlignment="Center"
                                                      Checked="ShowInvoiceReviewContextDetailsCheckBox_Changed"
                                                      Unchecked="ShowInvoiceReviewContextDetailsCheckBox_Changed" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Ana Aksiyonlar"
                                                   Style="{StaticResource MutedText}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6" />
                                        <WrapPanel ItemHeight="34">
                                            <CheckBox x:Name="ShowInvoiceReviewContextCheckBox"
                                                      Content="Bağlamı Göster"
                                                      IsChecked="True"
                                                      Margin="0,0,12,8"
                                                      VerticalAlignment="Center"
                                                      Checked="ShowInvoiceReviewContextCheckBox_Changed"
                                                      Unchecked="ShowInvoiceReviewContextCheckBox_Changed" />
                                            <Button x:Name="FocusInvoiceFromReviewContextButton"
                                                    Content="Bağlamdan İncele"
                                                    Style="{StaticResource ContextPrimaryActionButton}"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Review akisini baglamdan kurar (Ctrl+Shift+I)"
                                                    Click="FocusInvoiceFromReviewContextButton_Click" />
                                            <Button x:Name="ApplyInvoiceReviewContextNarrowButton"
                                                    Content="Bağlamı Daralt"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="context"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Filtre, donem, tur ve fatura no ipuclarini birlikte uygular"
                                                    Click="ApplyInvoiceReviewContextNarrowButton_Click" />
                                            <Button x:Name="ApplyInvoiceReviewContextFilterButton"
                                                    Content="Bağlam Filtresi"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="filter"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Baglamdan onerilen hizli filtreyi uygular"
                                                    Click="ApplyInvoiceReviewContextFilterButton_Click" />
                                            <Button x:Name="CopyInvoiceReviewContextButton"
                                                    Content="Bağlamı Kopyala"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="context"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Baglam etiketini panoya kopyalar"
                                                    Click="CopyInvoiceReviewContextButton_Click" />
                                            <Button x:Name="ClearInvoiceReviewContextButton"
                                                    Content="Bağlamı Temizle"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="detail"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Baglami ve review modu vurgularini temizler"
                                                    Click="ClearInvoiceReviewContextButton_Click" />
                                        </WrapPanel>
                                        <TextBlock Text="Detay Araçlari"
                                                   Style="{StaticResource MutedText}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,2,0,6" />
                                        <WrapPanel ItemHeight="34">
                                            <Button x:Name="ApplyInvoiceReviewContextPeriodButton"
                                                    Content="Bağlam Dönemi"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="period"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Baglamdaki donemi yil/ay filtresine uygular"
                                                    Click="ApplyInvoiceReviewContextPeriodButton_Click" />
                                            <Button x:Name="ApplyInvoiceReviewContextTypeButton"
                                                    Content="Bağlam Türü"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="detail"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Baglamdaki fatura turunu filtreye uygular"
                                                    Click="ApplyInvoiceReviewContextTypeButton_Click" />
                                            <Button x:Name="ApplyInvoiceReviewContextInvoiceNoButton"
                                                    Content="Bağlam No"
                                                    Style="{StaticResource ContextActionButton}"
                                                    Tag="detail"
                                                    Margin="0,0,8,8"
                                                    ToolTip="Baglamdaki fatura numarasini arama kutusuna uygular"
                                                    Click="ApplyInvoiceReviewContextInvoiceNoButton_Click" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="SaveInvoiceReviewNoteButton"
                                                Content="İnceleme Notunu Kaydet"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="SaveInvoiceReviewNoteButton_Click" />
                                        <Button x:Name="MarkReviewedAndNextButton"
                                                Content="Bakıldı + Sonraki"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="MarkReviewedAndNextButton_Click" />
                                        <Button x:Name="ClearInvoiceReviewNoteButton"
                                                Content="İşareti Temizle"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="ClearInvoiceReviewNoteButton_Click" />
                                        <Button Content="PDF Seç"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="SelectInvoicePdfButton_Click" />
                                        <Button x:Name="OpenInvoicePdfButton"
                                                Content="PDF Aç"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="OpenInvoicePdfButton_Click" />
                                        <Button x:Name="RevealInvoicePdfFolderButton"
                                                Content="Klasörde Göster"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="RevealInvoicePdfFolderButton_Click" />
                                        <Button x:Name="OpenInvoicePdfAndNextButton"
                                                Content="PDF Aç + Sonraki"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="OpenInvoicePdfAndNextButton_Click" />
                                        <Button x:Name="RevealInvoicePdfFolderAndNextButton"
                                                Content="Klasör + Sonraki"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="RevealInvoicePdfFolderAndNextButton_Click" />
                                        <Button x:Name="PreviousInvoiceButton"
                                                Content="Önceki Kayıt"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="PreviousInvoiceButton_Click" />
                                        <Button x:Name="NextInvoiceButton"
                                                Content="Sonraki Kayıt"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="NextInvoiceButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock x:Name="InvoiceStatusText"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <Button Content="Kaydet"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                Click="SaveInvoiceButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>








