<UserControl x:Class="FaturaTakip.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Raporlar"
                           Foreground="#1F2937"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Ödenmemiş, gecikmiş ve yaklaşan ödemeler"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="UnpaidTabButton"
                        Content="Ödenmemiş"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"
                        Click="UnpaidTabButton_Click" />
                <Button x:Name="OverdueTabButton"
                        Content="Gecikmiş"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="OverdueTabButton_Click" />
                <Button x:Name="UpcomingTabButton"
                        Content="Yaklaşan (7 gün)"
                        Style="{StaticResource SecondaryButton}"
                        Click="UpcomingTabButton_Click" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Margin="0,24,0,24">
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Ödenmemiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="UnpaidCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="UnpaidRemainingText"
                               Text="Kalan 0,00"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Gecikmiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="OverdueCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="OverdueRemainingText"
                               Text="Kalan 0,00"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}">
                <StackPanel>
                    <TextBlock Text="Yaklaşan (7 gün)"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="UpcomingCountText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="UpcomingRemainingText"
                               Text="Kalan 0,00"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource TileBorder}">
            <DataGrid x:Name="ReportGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      BorderBrush="#E5EAF1"
                      BorderThickness="1"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dönem"
                                        Binding="{Binding Period}"
                                        Width="70" />
                    <DataGridTextColumn Header="Tür"
                                        Binding="{Binding InvoiceTypeName}"
                                        Width="90" />
                    <DataGridTextColumn Header="Abonelik"
                                        Binding="{Binding SubscriptionName}"
                                        Width="1.0*" />
                    <DataGridTextColumn Header="Kurum"
                                        Binding="{Binding InstitutionName}"
                                        Width="1.0*" />
                    <DataGridTextColumn Header="Fatura No"
                                        Binding="{Binding InvoiceNo}"
                                        Width="95" />
                    <DataGridTextColumn Header="Son Ödeme"
                                        Binding="{Binding DueDateText}"
                                        Width="95" />
                    <DataGridTextColumn Header="Tutar"
                                        Binding="{Binding AmountText}"
                                        Width="90" />
                    <DataGridTextColumn Header="Ödenen"
                                        Binding="{Binding PaidAmountText}"
                                        Width="90" />
                    <DataGridTextColumn Header="Kalan"
                                        Binding="{Binding RemainingAmountText}"
                                        Width="90" />
                    <DataGridTextColumn Header="PDF"
                                        Binding="{Binding PdfState}"
                                        Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

