<UserControl x:Class="FaturaTakip.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="DiffBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ChangeType}" Value="Degisti">
                    <Setter Property="Background" Value="#FDE68A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeType}" Value="Eklendi">
                    <Setter Property="Background" Value="#BBF7D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeType}" Value="Silindi">
                    <Setter Property="Background" Value="#FECACA" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeType}" Value="Ayni">
                    <Setter Property="Background" Value="#E2E8F0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DiffBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ChangeType}" Value="Degisti">
                    <Setter Property="Foreground" Value="#92400E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeType}" Value="Eklendi">
                    <Setter Property="Foreground" Value="#166534" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeType}" Value="Silindi">
                    <Setter Property="Foreground" Value="#991B1B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeType}" Value="Ayni">
                    <Setter Property="Foreground" Value="#475569" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Raporlar"
                           Foreground="#1F2937"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Ödenmemiş, gecikmiş, yaklaşan ve aylık liste"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="UnpaidTabButton"
                        Content="Ödenmemiş"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"
                        Click="UnpaidTabButton_Click" />
                <Button x:Name="OverdueTabButton"
                        Content="Gecikmiş"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="OverdueTabButton_Click" />
                <Button x:Name="UpcomingTabButton"
                        Content="Yaklaşan (7 gün)"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="UpcomingTabButton_Click" />
                <Button x:Name="MonthlyTabButton"
                        Content="Aylık Liste"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="MonthlyTabButton_Click" />
                <Button x:Name="YearlyTabButton"
                        Content="Yıllık Liste"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="YearlyTabButton_Click" />
                <Button x:Name="SubscriptionTabButton"
                        Content="Abonelik"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="SubscriptionTabButton_Click" />
                <Button x:Name="SubscriptionYearlyTabButton"
                        Content="Abonelik Yıllık"
                        Style="{StaticResource SecondaryButton}"
                        Click="SubscriptionYearlyTabButton_Click" />
                <Button x:Name="TypeYearlyTabButton"
                        Content="Tür Yıllık"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="TypeYearlyTabButton_Click" />
                <Button x:Name="DocumentHealthTabButton"
                        Content="Evrak Kontrol"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="DocumentHealthTabButton_Click" />
                <Button x:Name="ConsistencyTabButton"
                        Content="Tutarlılık"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="ConsistencyTabButton_Click" />
                <Button x:Name="AuditLogTabButton"
                        Content="Ä°ÅŸlem GeÃ§miÅŸi"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="AuditLogTabButton_Click" />
                <Button x:Name="ExportReportButton"
                        Content="Excel'e Aktar"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="ExportReportButton_Click" />
                <Button x:Name="ExportReportPdfButton"
                        Content="PDF'e Aktar"
                        Style="{StaticResource SecondaryButton}"
                        Click="ExportReportPdfButton_Click" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="0,24,0,24">
            <Border x:Name="MonthlyFilterPanel"
                    Background="White"
                    BorderBrush="#DDE4EC"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Dönem:"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <ComboBox x:Name="MonthlyInvoiceTypeInput"
                              Width="220"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="MonthlyFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="MonthlyYearInput"
                              Width="110"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="MonthlyFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="MonthlyMonthInput"
                              Width="150"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="MonthlyFilter_Changed"
                              Margin="0,0,10,0" />
                    <TextBlock x:Name="MonthlyFilterHintText"
                               Text=""
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border x:Name="SubscriptionFilterPanel"
                    Background="White"
                    BorderBrush="#DDE4EC"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Abonelik:"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <ComboBox x:Name="SubscriptionInput"
                              Width="320"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SubscriptionFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="SubscriptionYearInput"
                              Width="110"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SubscriptionFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="SubscriptionMonthInput"
                              Width="150"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SubscriptionFilter_Changed"
                              Margin="0,0,10,0" />
                    <TextBlock x:Name="SubscriptionHintText"
                               Text=""
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border x:Name="TypeYearlyFilterPanel"
                    Background="White"
                    BorderBrush="#DDE4EC"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tür:"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <ComboBox x:Name="TypeYearlyInvoiceTypeInput"
                              Width="220"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="TypeYearlyFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="TypeYearlyYearInput"
                              Width="110"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="TypeYearlyFilter_Changed"
                              Margin="0,0,10,0" />
                    <TextBlock x:Name="TypeYearlyHintText"
                               Text=""
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <Border x:Name="AuditLogFilterPanel"
                    Background="White"
                    BorderBrush="#DDE4EC"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Ä°ÅŸlem:"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"
                               Margin="0,0,10,0" />
                    <ComboBox x:Name="AuditLogActionInput"
                              Width="240"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="AuditLogFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="AuditLogEntityInput"
                              Width="150"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="AuditLogFilter_Changed"
                              Margin="0,0,10,0" />
                    <ComboBox x:Name="AuditLogUserInput"
                              Width="150"
                              Height="34"
                              VerticalContentAlignment="Center"
                              SelectionChanged="AuditLogFilter_Changed"
                              Margin="0,0,10,0" />
                    <DatePicker x:Name="AuditLogStartDateInput"
                                Width="140"
                                SelectedDateChanged="AuditLogFilter_Changed"
                                Margin="0,0,10,0" />
                    <DatePicker x:Name="AuditLogEndDateInput"
                                Width="140"
                                SelectedDateChanged="AuditLogFilter_Changed"
                                Margin="0,0,10,0" />
                    <TextBox x:Name="AuditLogSearchInput"
                             Width="220"
                             Height="34"
                             VerticalContentAlignment="Center"
                             TextChanged="AuditLogSearchInput_TextChanged"
                             Margin="0,0,10,0" />
                    <TextBlock x:Name="AuditLogHintText"
                               Text=""
                               VerticalAlignment="Center"
                               Foreground="#64748B" />
                </StackPanel>
            </Border>

            <UniformGrid Columns="3">
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock x:Name="Tile1LabelText"
                               Text="Ödenmemiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="Tile1ValueText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="Tile1DetailText"
                               Text="Kalan 0,00"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock x:Name="Tile2LabelText"
                               Text="Gecikmiş"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="Tile2ValueText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="Tile2DetailText"
                               Text="Kalan 0,00"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource TileBorder}">
                <StackPanel>
                    <TextBlock x:Name="Tile3LabelText"
                               Text="Yaklaşan (7 gün)"
                               Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="Tile3ValueText"
                               Text="0"
                               Margin="0,10,0,0"
                               Foreground="#111827"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="Tile3DetailText"
                               Text="Kalan 0,00"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            </UniformGrid>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource TileBorder}">
            <Grid>
                <DataGrid x:Name="ReportGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          BorderBrush="#E5EAF1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dönem"
                                            Binding="{Binding Period}"
                                            Width="70" />
                        <DataGridTextColumn Header="Tür"
                                            Binding="{Binding InvoiceTypeName}"
                                            Width="90" />
                        <DataGridTextColumn Header="Abonelik"
                                            Binding="{Binding SubscriptionName}"
                                            Width="1.0*" />
                        <DataGridTextColumn Header="Kurum"
                                            Binding="{Binding InstitutionName}"
                                            Width="1.0*" />
                        <DataGridTextColumn Header="Durum"
                                            Binding="{Binding StatusText}"
                                            Width="80" />
                        <DataGridTextColumn Header="Fatura No"
                                            Binding="{Binding InvoiceNo}"
                                            Width="95" />
                        <DataGridTextColumn Header="Son Ödeme"
                                            Binding="{Binding DueDateText}"
                                            Width="95" />
                        <DataGridTextColumn Header="Tutar"
                                            Binding="{Binding AmountText}"
                                            Width="90" />
                        <DataGridTextColumn Header="Ödenen"
                                            Binding="{Binding PaidAmountText}"
                                            Width="90" />
                        <DataGridTextColumn Header="Kalan"
                                            Binding="{Binding RemainingAmountText}"
                                            Width="90" />
                        <DataGridTextColumn Header="PDF"
                                            Binding="{Binding PdfState}"
                                            Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="YearlyGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          BorderBrush="#E5EAF1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ay"
                                            Binding="{Binding MonthName}"
                                            Width="120" />
                        <DataGridTextColumn Header="Fatura"
                                            Binding="{Binding InvoiceCountText}"
                                            Width="70" />
                        <DataGridTextColumn Header="Toplam"
                                            Binding="{Binding TotalAmountText}"
                                            Width="120" />
                        <DataGridTextColumn Header="Ödenen"
                                            Binding="{Binding PaidText}"
                                            Width="120" />
                        <DataGridTextColumn Header="Kalan"
                                            Binding="{Binding RemainingText}"
                                            Width="120" />
                        <DataGridTextColumn Header="Ödenmemiş"
                                            Binding="{Binding UnpaidCountText}"
                                            Width="90" />
                        <DataGridTextColumn Header="Gecikmiş"
                                            Binding="{Binding OverdueCountText}"
                                            Width="90" />
                        <DataGridTextColumn Header="PDF Eksik"
                                            Binding="{Binding MissingPdfCountText}"
                                            Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="DistributionGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          BorderBrush="#E5EAF1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Abonelik"
                                            Binding="{Binding SubscriptionName}"
                                            Width="1.2*" />
                        <DataGridTextColumn Header="Kurum"
                                            Binding="{Binding InstitutionName}"
                                            Width="1.0*" />
                        <DataGridTextColumn Header="Fatura"
                                            Binding="{Binding InvoiceCountText}"
                                            Width="70" />
                        <DataGridTextColumn Header="Toplam"
                                            Binding="{Binding TotalAmountText}"
                                            Width="120" />
                        <DataGridTextColumn Header="Ödenen"
                                            Binding="{Binding PaidText}"
                                            Width="120" />
                        <DataGridTextColumn Header="Kalan"
                                            Binding="{Binding RemainingText}"
                                            Width="120" />
                        <DataGridTextColumn Header="PDF Eksik"
                                            Binding="{Binding MissingPdfCountText}"
                                            Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="DocumentHealthGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          BorderBrush="#E5EAF1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Uyarı"
                                            Binding="{Binding IssueType}"
                                            Width="110" />
                        <DataGridTextColumn Header="Tip"
                                            Binding="{Binding EntityType}"
                                            Width="70" />
                        <DataGridTextColumn Header="Dönem/Tarih"
                                            Binding="{Binding PeriodOrDate}"
                                            Width="120" />
                        <DataGridTextColumn Header="Tür"
                                            Binding="{Binding InvoiceTypeName}"
                                            Width="90" />
                        <DataGridTextColumn Header="Abonelik"
                                            Binding="{Binding SubscriptionName}"
                                            Width="1.0*" />
                        <DataGridTextColumn Header="Kurum"
                                            Binding="{Binding InstitutionName}"
                                            Width="1.0*" />
                        <DataGridTextColumn Header="Tutar"
                                            Binding="{Binding AmountText}"
                                            Width="90" />
                        <DataGridTextColumn Header="PDF"
                                            Binding="{Binding PdfState}"
                                            Width="90" />
                        <DataGridTextColumn Header="Yol"
                                            Binding="{Binding PdfFilePath}"
                                            Width="1.2*" />
                        <DataGridTextColumn Header="Hash"
                                            Binding="{Binding PdfSha256Hash}"
                                            Width="160" />
                        <DataGridTextColumn Header="Not"
                                            Binding="{Binding Note}"
                                            Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="ConsistencyGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          BorderBrush="#E5EAF1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Seviye"
                                            Binding="{Binding Severity}"
                                            Width="90" />
                        <DataGridTextColumn Header="Kod"
                                            Binding="{Binding Code}"
                                            Width="200" />
                        <DataGridTextColumn Header="Varlık"
                                            Binding="{Binding Entity}"
                                            Width="80" />
                        <DataGridTextColumn Header="Id"
                                            Binding="{Binding EntityId}"
                                            Width="80" />
                        <DataGridTextColumn Header="Mesaj"
                                            Binding="{Binding Message}"
                                            Width="1.5*" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="AuditLogGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="AuditLogGrid_SelectionChanged"
                          BorderBrush="#E5EAF1"
                          BorderThickness="1"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tarih"
                                            Binding="{Binding CreatedAtText}"
                                            Width="130" />
                        <DataGridTextColumn Header="Ä°ÅŸlem"
                                            Binding="{Binding ActionType}"
                                            Width="170" />
                        <DataGridTextColumn Header="VarlÄ±k"
                                            Binding="{Binding TableName}"
                                            Width="110" />
                        <DataGridTextColumn Header="KayÄ±t Id"
                                            Binding="{Binding RecordIdText}"
                                            Width="90" />
                        <DataGridTextColumn Header="AÃ§Ä±klama"
                                            Binding="{Binding Description}"
                                            Width="1.5*" />
                        <DataGridTextColumn Header="KullanÄ±cÄ±"
                                            Binding="{Binding UserName}"
                                            Width="100" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="AuditLogDetailPanel"
                        Visibility="Collapsed"
                        Margin="0,12,0,0"
                        Padding="14"
                        Background="#F8FAFC"
                        BorderBrush="#DDE4EC"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock x:Name="AuditLogDetailTitleText"
                                   Text="Kayit detayi"
                                   Foreground="#0F172A"
                                   FontWeight="SemiBold"
                                   FontSize="15" />
                        <TextBlock x:Name="AuditLogDetailMetaText"
                                   Text=""
                                   Foreground="#64748B"
                                   Margin="0,4,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Eski Deger"
                                               Foreground="#334155"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left" />
                                    <Button x:Name="CopyOldAuditLogButton"
                                            Content="Kopyala"
                                            MinWidth="78"
                                            Padding="10,4"
                                            HorizontalAlignment="Right"
                                            Click="CopyOldAuditLogButton_Click" />
                                </DockPanel>
                                <TextBox x:Name="AuditLogOldValueTextBox"
                                         Height="160"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         IsReadOnly="True" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Yeni Deger"
                                               Foreground="#334155"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left" />
                                    <Button x:Name="CopyNewAuditLogButton"
                                            Content="Kopyala"
                                            MinWidth="78"
                                            Padding="10,4"
                                            HorizontalAlignment="Right"
                                            Click="CopyNewAuditLogButton_Click" />
                                </DockPanel>
                                <TextBox x:Name="AuditLogNewValueTextBox"
                                         Height="160"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         IsReadOnly="True" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Alan Bazli Fark"
                                   Foreground="#334155"
                                   FontWeight="SemiBold"
                                   Margin="0,12,0,6" />
                        <DockPanel Margin="0,0,0,8">
                            <CheckBox x:Name="AuditLogDiffChangedOnlyCheckBox"
                                      Content="Sadece degisen alanlari goster"
                                      VerticalAlignment="Center"
                                      DockPanel.Dock="Left"
                                      Checked="AuditLogDiffFilter_Changed"
                                      Unchecked="AuditLogDiffFilter_Changed" />
                            <Button x:Name="CopyAuditLogDiffButton"
                                    Content="Tum diff'i kopyala"
                                    MinWidth="132"
                                    Padding="10,4"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right"
                                    Click="CopyAuditLogDiffButton_Click" />
                        </DockPanel>
                        <DataGrid x:Name="AuditLogDiffGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  BorderBrush="#DDE4EC"
                                  BorderThickness="1"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Height="180">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Alan"
                                                    Binding="{Binding FieldName}"
                                                    Width="1.1*" />
                                <DataGridTextColumn Header="Eski"
                                                    Binding="{Binding OldValue}"
                                                    Width="1.2*" />
                                <DataGridTextColumn Header="Yeni"
                                                    Binding="{Binding NewValue}"
                                                    Width="1.2*" />
                                <DataGridTemplateColumn Header="Durum"
                                                        Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DiffBadgeBorderStyle}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ChangeType}"
                                                           Style="{StaticResource DiffBadgeTextStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

