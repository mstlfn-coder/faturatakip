<UserControl x:Class="FaturaTakip.App.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Yedekleme"
                       Foreground="#1F2937"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="Veritabani + ekler + rapor ciktisi icin tek tikla zip yedek"
                       Style="{StaticResource MutedText}"
                       Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource TileBorder}"
                Margin="0,24,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="BackupStatusText"
                           Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <CheckBox x:Name="IncludeAttachmentsCheck"
                              Content="attachments dahil"
                              IsChecked="True"
                              Margin="0,0,18,0" />
                    <CheckBox x:Name="IncludeExportsCheck"
                              Content="exports dahil"
                              IsChecked="True" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <Button Content="Yedek Olustur"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Click="CreateBackupButton_Click" />
                    <Button Content="Klasoru Ac"
                            Style="{StaticResource SecondaryButton}"
                            Click="OpenBackupsFolderButton_Click" />
                </StackPanel>

                <Border Grid.Row="3"
                        BorderBrush="#EEF2F7"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Son Yedekler"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <ListBox Grid.Row="1"
                                 x:Name="RecentBackupsList"
                                 MinHeight="120"
                                 DisplayMemberPath="DisplayText"
                                 SelectionChanged="RecentBackupsList_SelectionChanged" />

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    Margin="0,10,0,0">
                            <Button x:Name="RefreshBackupsListButton"
                                    Content="Listeyi Yenile"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="120"
                                    Margin="0,0,8,0"
                                    Click="RefreshBackupsListButton_Click" />
                            <Button x:Name="UseSelectedBackupButton"
                                    Content="Secileni Kullan"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="130"
                                    Margin="0,0,8,0"
                                    Click="UseSelectedBackupButton_Click" />
                            <Button x:Name="OpenSelectedBackupButton"
                                    Content="Zipi Ac"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="110"
                                    Margin="0,0,8,0"
                                    Click="OpenSelectedBackupButton_Click" />
                            <Button x:Name="RevealSelectedBackupButton"
                                    Content="Klasorde Goster"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="130"
                                    Margin="0,0,8,0"
                                    Click="RevealSelectedBackupButton_Click" />
                            <TextBlock x:Name="RecentBackupsStatusText"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        BorderBrush="#EEF2F7"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Geri Yukleme (Bos Klasore)"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RestoreZipPathText"
                                     IsReadOnly="True"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1"
                                    Content="Zip Sec"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="110"
                                    Margin="0,0,14,0"
                                    Click="SelectRestoreZipButton_Click" />
                            <TextBox Grid.Column="2"
                                     x:Name="RestoreTargetPathText"
                                     ToolTip="Bos hedef klasor yolunu yazin"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="3"
                                    Content="Hedef Sec"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="110"
                                    Click="SelectRestoreTargetButton_Click" />
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,10,0,0">
                            <Button Content="Geri Yukle"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"
                                    Click="RestoreBackupButton_Click" />
                             <Button Content="Hedefi Ac"
                                     Style="{StaticResource SecondaryButton}"
                                     MinWidth="110"
                                     Margin="0,0,10,0"
                                     Click="OpenRestoreTargetButton_Click" />
                            <TextBlock x:Name="RestoreStatusText"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

