<Window x:Class="FaturaTakip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kurum Fatura Takip"
        Height="720"
        Width="1120"
        MinHeight="640"
        MinWidth="980"
        Background="#F3F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#223047">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Kurum Fatura"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="1"
                           Margin="0,6,0,28"
                           Text="Takip Programı"
                           Foreground="#B8C4D6"
                           FontSize="14" />

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Gösterge Paneli"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18" />
                    <TextBlock Text="Fatura Türleri"
                               Foreground="#94A3B8"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Abonelikler"
                               Foreground="#94A3B8"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Faturalar"
                               Foreground="#94A3B8"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Ödemeler"
                               Foreground="#94A3B8"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Raporlar"
                               Foreground="#94A3B8" />
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Text="v0.1"
                           Foreground="#94A3B8"
                           FontSize="13" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Gösterge Paneli"
                               Foreground="#1F2937"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Başlangıç durumu"
                               Style="{StaticResource MutedText}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E7EEF6"
                        BorderBrush="#CFDAE8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="InitializedAtText"
                               Foreground="#334155"
                               FontSize="13" />
                </Border>
            </Grid>

            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,24,0,24">
                <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Aktif Abonelik"
                                   Style="{StaticResource MutedText}" />
                        <TextBlock Text="0"
                                   Margin="0,10,0,0"
                                   Foreground="#111827"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Bu Ay Fatura"
                                   Style="{StaticResource MutedText}" />
                        <TextBlock Text="0"
                                   Margin="0,10,0,0"
                                   Foreground="#111827"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Ödenmemiş"
                                   Style="{StaticResource MutedText}" />
                        <TextBlock Text="0"
                                   Margin="0,10,0,0"
                                   Foreground="#111827"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TileBorder}">
                    <StackPanel>
                        <TextBlock Text="Evrak Eksik"
                                   Style="{StaticResource MutedText}" />
                        <TextBlock Text="0"
                                   Margin="0,10,0,0"
                                   Foreground="#111827"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource TileBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Sistem Durumu"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <Grid Grid.Row="1" Margin="0,18,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Veritabanı"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DatabaseStateText"
                                       Grid.Column="1"
                                       Foreground="#166534"
                                       FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1"
                                       Text="Migration"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,10,0,0" />
                            <TextBlock x:Name="MigrationStateText"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Foreground="#334155"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,0" />

                            <TextBlock Grid.Row="2"
                                       Text="Proje Kökü"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,10,0,0" />
                            <TextBlock x:Name="RootPathText"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Foreground="#334155"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />
                        </Grid>

                        <ListView x:Name="DirectoryList"
                                  Grid.Row="2"
                                  BorderBrush="#E5EAF1"
                                  BorderThickness="1">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Klasör"
                                                    Width="180"
                                                    DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Durum"
                                                    Width="110"
                                                    DisplayMemberBinding="{Binding State}" />
                                    <GridViewColumn Header="Yol"
                                                    Width="360"
                                                    DisplayMemberBinding="{Binding FullPath}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource TileBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Veritabanı"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="DatabasePathText"
                                   Grid.Row="1"
                                   Margin="0,16,0,18"
                                   Foreground="#334155"
                                   TextWrapping="Wrap" />

                        <ItemsControl x:Name="MigrationList" Grid.Row="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5EAF1"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,10">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#334155"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Grid.Row="3"
                       Margin="0,18,0,0"
                       Text="Fatura Türü -> Abonelik -> Fatura -> Ödeme -> Evraklar"
                       Style="{StaticResource MutedText}" />
        </Grid>
    </Grid>
</Window>
