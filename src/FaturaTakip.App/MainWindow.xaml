                                               Visibility="Collapsed" />
                                    <TextBlock x:Name="PaymentsDocumentTargetText"
                                               Text="Hedef: Eksik odeme PDF listesini ac."
                                               Foreground="#1D4ED8"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="16"
                                               LineStackingStrategy="BlockLineHeight"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                    <TextBlock x:Name="PaymentsDocumentNextStepText"
                                               Text="Sonraki adim: eksik kaydi acip PDF evrakini tamamla."
                                               Foreground="#4B7FE0"
                                               FontSize="10"
                                               LineHeight="15"
                                               LineStackingStrategy="BlockLineHeight"
                                               Margin="0,1,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                    <Border x:Name="PaymentsDocumentShortcutHint"
                                            Background="#EFF6FF"
                                            BorderBrush="#BFDBFE"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            HorizontalAlignment="Left"
                                            Margin="0,4,0,0"
                                            Padding="7,2"
                                            Visibility="Collapsed">
                                        <TextBlock Text="Enter ile ac"
                                                   Foreground="#3B82F6"
                                                   FontSize="9"
                                                   FontWeight="Normal" />
                                    </Border>
                                    <Button Content="Eksik Evrak Raporunu Ac"
                                            x:Name="PaymentsDocumentActionButton"
                                            Style="{StaticResource PaymentsFlowSecondaryActionButton}"
                                            Margin="0,5,0,0"
                                            HorizontalAlignment="Left"
                                            ToolTip="Eksik odeme PDF kayitlarini raporda acar. Enter ile tetiklenebilir."
                                            Click="OpenDocumentHealthReportFromPaymentsButton_Click" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource PaymentsFlowCard}"
                                    x:Name="PaymentsUnpaidReportFlowCard"
                                    Tag="flow_unpaid_report"
                                    MouseEnter="PaymentsHintSource_MouseEnter"
                                    MouseLeave="PaymentsHintSource_MouseLeave">
                                <StackPanel>
                                    <Border Style="{StaticResource FlowBadgeBorder}"
                                            Background="#FEF3C7"
                                            BorderBrush="#FCD34D">
                                        <TextBlock Text="RAPOR"
                                                   Style="{StaticResource FlowBadgeText}"
                                                   Foreground="#B45309" />
                                    </Border>
                                    <Border x:Name="PaymentsUnpaidReportActiveColumnBadge"
                                            Background="#C2410C"
                                            BorderBrush="#C2410C"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            HorizontalAlignment="Left"
                                            Margin="0,5,0,0"
                                            Padding="6,2"
                                            Visibility="Collapsed">
                                        <TextBlock Text="AKTIF KOLON"
                                                   Foreground="White"
                                                   FontSize="9"
                                                   FontWeight="Normal" />
                                    </Border>
                                    <TextBlock x:Name="PaymentsUnpaidReportTitleText"
                                               Text="Odenmemis bakiyeyi rapor akisinda izle"
                                               Foreground="#1F2937"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="PaymentsUnpaidReportDescriptionText"
                                               Text="Kalan toplam ve acik faturalari rapor sekmesinde ac."
                                               Style="{StaticResource MutedText}"
                                               Foreground="#6B7280"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="Ustte Bu Ay Odeme ve Odenmemis Faturalar ozetleri ile birlikte okunur."
                                               Foreground="#C2410C"
                                               FontSize="11"
                                               FontWeight="Normal"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="PaymentsUnpaidReportActiveRouteNote"
                                               Text="Aktif yol"
                                               Foreground="#E46A28"
                                               FontSize="10"
                                               FontWeight="Normal"
                                               Margin="0,3,0,0"
                                               Visibility="Collapsed" />
                                    <TextBlock x:Name="PaymentsUnpaidReportTargetText"
                                               Text="Hedef: Odenmemisler raporunda acik bakiyeyi incele."
                                               Foreground="#B45309"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               LineHeight="16"
                                               LineStackingStrategy="BlockLineHeight"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                    <TextBlock x:Name="PaymentsUnpaidReportNextStepText"
                                               Text="Sonraki adim: acik bakiyeyi filtreleyip uygun tahsilat kaydina ilerle."
                                               Foreground="#CB6432"
                                               FontSize="10"
                                               LineHeight="15"
                                               LineStackingStrategy="BlockLineHeight"
                                               Margin="0,1,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed" />
                                    <Border x:Name="PaymentsUnpaidReportShortcutHint"
                                            Background="#FFFBEB"
                                            BorderBrush="#FDE68A"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            HorizontalAlignment="Left"
                                            Margin="0,4,0,0"
                                            Padding="7,2"
                                            Visibility="Collapsed">
                                        <TextBlock Text="Enter ile ac"
                                                   Foreground="#EA580C"
                                                   FontSize="9"
                                                   FontWeight="Normal" />
                                    </Border>
                                    <Button Content="Odenmemisler Raporunu Ac"
                                            x:Name="PaymentsUnpaidReportActionButton"
                                            Style="{StaticResource PaymentsFlowSecondaryActionButton}"
                                            Margin="0,5,0,0"
                                            HorizontalAlignment="Left"
                                            ToolTip="Odenmemis faturalar raporunu acar. Enter ile tetiklenebilir."
                                            Click="OpenUnpaidReportFromPaymentsButton_Click" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="3"
                              Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource PaymentsOpsCard}">
                                <StackPanel>
                                    <TextBlock Text="Odeme Calisma Kuyrugu"
                                               Foreground="#1F2937"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="PaymentsQueueSummaryText"
                                               Text="Odenmemis odemeler burada listelenir."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="PaymentsQueueFilterAllButton"
                                                Content="Hepsi"
                                                Style="{StaticResource PaymentsFilterButton}"
                                                ToolTip="En yakin bes kuyruk kaydinin tamamini gosterir."
                                                Click="PaymentsQueueFilterButton_Click" />
                                        <Button x:Name="PaymentsQueueFilterUrgentButton"
                                                Content="Acil"
                                                Style="{StaticResource PaymentsFilterButton}"
                                                ToolTip="En yakin bes kayit icindeki acil odemeleri gosterir."
                                                Click="PaymentsQueueFilterButton_Click" />
                                        <Button x:Name="PaymentsQueueFilterMissingPdfButton"
                                                Content="PDF Eksik"
                                                Style="{StaticResource PaymentsFilterButton}"
                                                ToolTip="En yakin bes kayit icindeki PDF eksik faturalarini gosterir."
                                                Click="PaymentsQueueFilterButton_Click" />
                                    </StackPanel>
                                    <Border x:Name="PaymentsQueueActiveFilterBadge"
                                            Style="{StaticResource PaymentsActiveFilterBadge}"
                                            Margin="0,6,0,0"
                                            ToolTip="Odeme kuyrugunda uygulanan guncel gorunumu gosterir.">
                                        <TextBlock x:Name="PaymentsQueueActiveFilterText"
                                                   Text="AKTIF KUYRUK: TUM KUYRUK"
                                                   Foreground="#1D4ED8"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <Button x:Name="PaymentsOpenNextQueueButton"
                                                Content="En Yakin Kaydi Ac"
                                                Style="{StaticResource PaymentsOpsActionButton}"
                                                Padding="12,4"
                                                ToolTip="Enter ile oncelikli kuyruk kaydini acar."
                                                Click="OpenNextQueueInvoiceButton_Click" />
                                        <TextBlock x:Name="PaymentsQueueActionHintText"
                                                   Text="Sonuc yoksa farkli bir filtre secin veya Hepsini Goster ile geri donun."
                                                   Style="{StaticResource MutedText}"
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   Margin="12,4,0,0"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <Button x:Name="PaymentsQueueResetFilterButton"
                                                Content="Hepsini Goster"
                                                Style="{StaticResource PaymentsResetFilterButton}"
                                                Margin="12,0,0,0"
                                                Padding="10,3"
                                                FontSize="11"
                                                Visibility="Collapsed"
                                                ToolTip="Kuyruk filtresini tum kayitlara geri dondurur."
                                                Click="ResetPaymentsQueueFilterButton_Click" />
                                    </StackPanel>
                                    <ItemsControl x:Name="PaymentsQueueItemsControl"
                                                  Margin="0,14,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PaymentsOpsItemBorder}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="#1F2937"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Meta}"
                                                                       Style="{StaticResource MutedText}"
                                                                       Margin="0,4,0,0"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1"
                                                                    Margin="16,0,0,0"
                                                                    HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Amount}"
                                                                       Foreground="#166534"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right" />
                                                            <Border Style="{StaticResource PaymentsOpsStatusBadge}"
                                                                    Background="{Binding StatusBackground}"
                                                                    BorderBrush="{Binding StatusBorder}"
                                                                    Margin="0,6,0,0">
                                                                <TextBlock Text="{Binding Status}"
                                                                           Foreground="{Binding StatusForeground}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           HorizontalAlignment="Right" />
                                                            </Border>
                                                            <Button Content="Ac"
                                                                    Style="{StaticResource PaymentsOpsActionButton}"
                                                                    Margin="0,8,0,0"
                                                                    Padding="10,3"
                                                                    FontSize="11"
                                                                    HorizontalAlignment="Right"
                                                                    Tag="{Binding InvoiceId}"
                                                                    ToolTip="Bu acik faturayi odeme alaninda hedefli olarak acar."
                                                                    Click="OpenPaymentsQueueInvoiceButton_Click" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource PaymentsOpsCard}">
                                <StackPanel>
                                    <TextBlock Text="Son Odemeler"
                                               Foreground="#1F2937"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="PaymentsRecentPaymentsSummaryText"
                                               Text="Son odemeler burada listelenir."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,10,0,0">
                                        <Button x:Name="PaymentsRecentFilterAllButton"
                                                Content="Hepsi"
                                                Style="{StaticResource PaymentsFilterButton}"
                                                ToolTip="En son bes odeme kaydinin tamamini gosterir."
                                                Click="PaymentsRecentFilterButton_Click" />
                                        <Button x:Name="PaymentsRecentFilterMissingPdfButton"
                                                Content="PDF Eksik"
                                                Style="{StaticResource PaymentsFilterButton}"
                                                ToolTip="En son bes odeme icindeki PDF eksik kayitlari gosterir."
                                                Click="PaymentsRecentFilterButton_Click" />
                                    </StackPanel>
                                    <Border x:Name="PaymentsRecentActiveFilterBadge"
                                            Style="{StaticResource PaymentsActiveFilterBadge}"
                                            Margin="0,6,0,0"
                                            ToolTip="Son odemelerde uygulanan guncel gorunumu gosterir.">
                                        <TextBlock x:Name="PaymentsRecentActiveFilterText"
                                                   Text="AKTIF SON ODEME: TUM SON ODEMELER"
                                                   Foreground="#1D4ED8"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <Button x:Name="PaymentsOpenLatestPaymentButton"
                                                Content="Son Odemeyi Ac"
                                                Style="{StaticResource PaymentsOpsActionButton}"
                                                Padding="12,4"
                                                ToolTip="Enter ile son odeme kaydini acar."
                                                Click="OpenLatestPaymentFromPaymentsButton_Click" />
                                        <TextBlock x:Name="PaymentsRecentActionHintText"
                                                   Text="Sonuc yoksa farkli bir filtre secin veya Hepsini Goster ile geri donun."
                                                   Style="{StaticResource MutedText}"
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   Margin="12,4,0,0"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                        <Button x:Name="PaymentsRecentResetFilterButton"
                                                Content="Hepsini Goster"
                                                Style="{StaticResource PaymentsResetFilterButton}"
                                                Margin="12,0,0,0"
                                                Padding="10,3"
                                                FontSize="11"
                                                Visibility="Collapsed"
                                                ToolTip="Son odeme filtresini tum kayitlara geri dondurur."
                                                Click="ResetPaymentsRecentFilterButton_Click" />
                                    </StackPanel>
                                    <ItemsControl x:Name="PaymentsRecentPaymentsItemsControl"
                                                  Margin="0,14,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PaymentsOpsItemBorder}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="#1F2937"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Meta}"
                                                                       Style="{StaticResource MutedText}"
                                                                       Margin="0,4,0,0"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1"
                                                                    Margin="16,0,0,0"
                                                                    HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Amount}"
                                                                       Foreground="#1D4ED8"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right" />
                                                            <Border Style="{StaticResource PaymentsOpsStatusBadge}"
                                                                    Background="{Binding StatusBackground}"
                                                                    BorderBrush="{Binding StatusBorder}"
                                                                    Margin="0,6,0,0">
                                                                <TextBlock Text="{Binding Status}"
                                                                           Foreground="{Binding StatusForeground}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           HorizontalAlignment="Right" />
                                                            </Border>
                                                            <Button Content="Ac"
                                                                    Style="{StaticResource PaymentsOpsActionButton}"
                                                                    Margin="0,8,0,0"
                                                                    Padding="10,3"
                                                                    FontSize="11"
                                                                    HorizontalAlignment="Right"
                                                                    Tag="{Binding InvoiceId}"
                                                                    ToolTip="Bu odemenin ait oldugu faturayi odeme alaninda yeniden acar."
                                                                    Click="OpenRecentPaymentInvoiceButton_Click" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            <views:ReportsView x:Name="ReportsPanel"
                               Visibility="Collapsed" />

            <views:BackupView x:Name="BackupPanel"
                              Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>

