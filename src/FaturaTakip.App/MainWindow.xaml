<Window x:Class="FaturaTakip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FaturaTakip.App.Views"
        mc:Ignorable="d"
        Title="Kurum Fatura Takip"
        Height="760"
        Width="1180"
        MinHeight="700"
        MinWidth="1040"
        Background="#F3F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="TileBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E7EEF6" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="BorderBrush" Value="#CFDAE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PaymentsFlowPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="BorderBrush" Value="#BFDBFE" />
                    <Setter Property="Background" Value="#2563EB" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentsFlowSecondaryActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#F2F6FB" />
            <Setter Property="BorderBrush" Value="#D6E2EE" />
            <Setter Property="Foreground" Value="#475569" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                    <Setter Property="Background" Value="#F8FBFF" />
                    <Setter Property="Foreground" Value="#1D4ED8" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="FlowBadgeBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="FlowBadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PaymentsSummaryCard" TargetType="Border" BasedOn="{StaticResource TileBorder}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentsFlowCard" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Opacity" Value="0.99" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFE" />
                    <Setter Property="BorderBrush" Value="#C9DCF4" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                             To="1.005"
                                             Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                             To="1.005"
                                             Duration="0:0:0.16" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0.99"
                                             Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.16" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentsOpsCard" TargetType="Border" BasedOn="{StaticResource TileBorder}">
            <Setter Property="Background" Value="#FCFDFE" />
            <Setter Property="BorderBrush" Value="#D9E2EC" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="PaymentsOpsItemBorder" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                    <Setter Property="BorderBrush" Value="#CBD5E1" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#EFF6FF" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentsOpsStatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <Style x:Key="PaymentsFilterButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8E2EC" />
            <Setter Property="Foreground" Value="#475569" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="BorderBrush" Value="#2563EB" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentsOpsActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#EFF6FF" />
                    <Setter Property="BorderBrush" Value="#2563EB" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PaymentsResetFilterButton" TargetType="Button" BasedOn="{StaticResource PaymentsOpsActionButton}">
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PaymentsActiveFilterBadge" TargetType="Border">
            <Setter Property="Background" Value="#EFF6FF" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#223047">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Kurum Fatura"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="1"
                           Margin="0,6,0,28"
                           Text="Takip Programı"
                           Foreground="#B8C4D6"
                           FontSize="14" />

                <StackPanel Grid.Row="2">
                    <Button x:Name="DashboardNavButton"
                            Content="Gösterge Paneli"
                            Style="{StaticResource NavButton}"
                            Click="DashboardNavButton_Click" />
                    <Button x:Name="InvoiceTypesNavButton"
                            Content="Fatura Türleri"
                            Style="{StaticResource NavButton}"
                            Click="InvoiceTypesNavButton_Click" />
                    <Button x:Name="SubscriptionsNavButton"
                            Content="Abonelikler"
                            Style="{StaticResource NavButton}"
                            Click="SubscriptionsNavButton_Click" />
                    <Button x:Name="InvoicesNavButton"
                            Content="Faturalar"
                            Style="{StaticResource NavButton}"
                            Click="InvoicesNavButton_Click" />
                    <Button x:Name="PaymentsNavButton"
                            Content="Odemeler"
                            Style="{StaticResource NavButton}"
                            Click="PaymentsNavButton_Click" />
                    <Button x:Name="ReportsNavButton"
                            Content="Raporlar"
                            Style="{StaticResource NavButton}"
                            Click="ReportsNavButton_Click" />
                    <Button x:Name="BackupNavButton"
                            Content="Yedekleme"
                            Style="{StaticResource NavButton}"
                            Click="BackupNavButton_Click" />
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Text="v0.19"
                           Foreground="#94A3B8"
                           FontSize="13" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid x:Name="DashboardPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Gösterge Paneli"
                                   Foreground="#1F2937"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Aylık durum, tahsilat ve evrak eksikleri"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#E7EEF6"
                            BorderBrush="#CFDAE8"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="InitializedAtText"
                                   Foreground="#334155"
                                   FontSize="13" />
                    </Border>
                </Grid>

                <UniformGrid Grid.Row="1"
                             Columns="5"
                             Margin="0,24,0,24">
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Bu Ay Fatura"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardMonthlyInvoiceTotalText"
                                       Text="0,00"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DashboardMonthlyInvoiceCountText"
                                       Text="0 kayıt"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0" />
                            <Button Content="Listeye Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenMonthlyReportFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Bu Ay Ödeme"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardMonthlyPaymentTotalText"
                                       Text="0,00"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DashboardMonthlyPaymentCountText"
                                       Text="0 kayıt"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0" />
                            <Button Content="Listeye Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenMonthlyReportFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="İnceleme Bekleyen"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardUnreviewedInvoiceCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="İncelenmedi kayıtlar"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0" />
                            <Button Content="Faturalara Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenUnreviewedInvoicesFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Ödenmemiş"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardUnpaidInvoiceCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DashboardUnpaidRemainingText"
                                       Text="Kalan 0,00"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0" />
                            <Button Content="Rapora Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenUnpaidReportFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}">
                        <StackPanel>
                            <TextBlock Text="Gecikmiş"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardOverdueInvoiceCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DashboardOverdueRemainingText"
                                       Text="Kalan 0,00"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,6,0,0" />
                            <Button Content="Rapora Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenOverdueReportFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid Grid.Row="2"
                             Columns="3"
                             Margin="0,0,0,24">
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,12">
                        <StackPanel>
                            <TextBlock Text="Fatura PDF Eksik"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardMissingInvoicePdfCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <Button Content="Kontrole Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenDocumentHealthReportFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,12">
                        <StackPanel>
                            <TextBlock Text="Ödeme PDF Eksik"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardMissingPaymentPdfCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <Button Content="Kontrole Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenDocumentHealthReportFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Fatura Türü"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardInvoiceTypeCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <Button Content="Turlere Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenInvoiceTypesFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Aktif Tür"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardActiveInvoiceTypeCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <Button Content="Turlere Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenInvoiceTypesFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Aktif Abonelik"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardActiveSubscriptionCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <Button Content="Aboneliklere Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenSubscriptionsFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TileBorder}">
                        <StackPanel>
                            <TextBlock Text="Toplam Fatura"
                                       Style="{StaticResource MutedText}" />
                            <TextBlock x:Name="DashboardInvoiceCountText"
                                       Text="0"
                                       Margin="0,10,0,0"
                                       Foreground="#111827"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <Button Content="Faturalara Git"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="OpenInvoicesFromDashboardButton_Click" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource TileBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Sistem Durumu"
                                       Foreground="#1F2937"
                                       FontSize="18"
                                       FontWeight="SemiBold" />

                            <Grid Grid.Row="1" Margin="0,18,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Veritabanı"
                                           Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="DatabaseStateText"
                                           Grid.Column="1"
                                           Foreground="#166534"
                                           FontWeight="SemiBold" />

                                <TextBlock Grid.Row="1"
                                           Text="Migration"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,10,0,0" />
                                <TextBlock x:Name="MigrationStateText"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Foreground="#334155"
                                           FontWeight="SemiBold"
                                           Margin="0,10,0,0" />

                                <TextBlock Grid.Row="2"
                                           Text="Proje Kökü"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,10,0,0" />
                                <TextBlock x:Name="RootPathText"
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           Foreground="#334155"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0" />
                            </Grid>

                            <ListView x:Name="DirectoryList"
                                      Grid.Row="2"
                                      BorderBrush="#E5EAF1"
                                      BorderThickness="1">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Klasör"
                                                        Width="180"
                                                        DisplayMemberBinding="{Binding Name}" />
                                        <GridViewColumn Header="Durum"
                                                        Width="110"
                                                        DisplayMemberBinding="{Binding State}" />
                                        <GridViewColumn Header="Yol"
                                                        Width="360"
                                                        DisplayMemberBinding="{Binding FullPath}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource TileBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Veritabanı"
                                       Foreground="#1F2937"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DatabasePathText"
                                       Grid.Row="1"
                                       Margin="0,16,0,18"
                                       Foreground="#334155"
                                       TextWrapping="Wrap" />

                            <ItemsControl x:Name="MigrationList" Grid.Row="2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5EAF1"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,10">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#334155"
